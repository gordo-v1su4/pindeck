
############################
# Convex – Client (Frontend)
############################

# Used by the browser / Vite app
# MUST be the .convex.cloud URL (not .site)
VITE_CONVEX_URL=https://tremendous-jaguar-953.convex.cloud


############################
# Convex – Deployment (CI)
############################

# Used by Vercel during build to deploy Convex
# Production values shown here
CONVEX_DEPLOYMENT=tremendous-jaguar-953
CONVEX_DEPLOY_KEY=


############################
# Backend / AI Providers
# (used INSIDE Convex actions)
############################

OPEN_ROUTER_KEY=
GOOGLE_API_KEY=
FAL_KEY=
JWT_PRIVATE_KEY=
####-----BEGIN PRIVATE KEY----- ... ... -----END PRIVATE KEY-----

# Convex Auth OAuth (Google/GitHub)
# Required for OAuth providers configured in convex/auth.ts
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Public site URL used for OAuth redirects (no trailing slash)
# Example: https://pindeck.app
SITE_URL=

############################
# Optional / Other
############################

# Only needed if your frontend or server (Vercel)
# calls these providers directly.
# Otherwise leave empty.
# N8N_MCP_API_KEY=

############################
# Discord Bot / Ingest integration
############################

# NOTE:
# The Discord bot + media gateway are hosted/deployed from:
#   ~/Documents/Github/discord-bot
# This repo only references their runtime env inputs.

# Discord bot token used by the external discord-bot service
DISCORD_TOKEN=

# Discord Application ID (recommended; auto-derived from token if omitted)
DISCORD_CLIENT_ID=

# Optional: limit bot operations to one guild/server
DISCORD_GUILD_ID=

# Image presets used by the external discord-bot service
# Example:
# DISCORD_IMAGES_JSON=[{"id":"welcome-banner","label":"Welcome Banner","url":"https://example.com/welcome.png","emoji":"🎉"}]
DISCORD_IMAGES_JSON=

# Optional: custom emoji/unicode triggers that import reacted message images into Pindeck
# Works for normal posts and RSS-forwarded posts
# Example: DISCORD_INGEST_EMOJIS=📥,<:pindeck:123456789012345678>
DISCORD_INGEST_EMOJIS=

# Optional: override ingest endpoint used by the bot (defaults to <CONVEX_SITE_URL>/ingestExternal)
PINDECK_INGEST_URL=

# Optional: override Discord queue/moderation endpoints
# Defaults: <CONVEX_SITE_URL>/discordQueue and <CONVEX_SITE_URL>/discordModerate
PINDECK_DISCORD_QUEUE_URL=
PINDECK_DISCORD_MODERATION_URL=

# API key required by convex/http.ts /ingestExternal
INGEST_API_KEY=

# Nextcloud WebDAV (primary media storage)
NEXTCLOUD_WEBDAV_BASE_URL=https://cloud.v1su4.dev/remote.php/dav/files/gordo
NEXTCLOUD_WEBDAV_USER=gordo
NEXTCLOUD_WEBDAV_APP_PASSWORD=
NEXTCLOUD_UPLOAD_PREFIX=pindeck/media-uploads

# Optional: Discord webhook URL for status updates (queued/approved/rejected/generated),
# create this in #pindeck-connect channel settings -> Integrations -> Webhooks
DISCORD_STATUS_WEBHOOK_URL=

# Convex userId destination for Discord imports
PINDECK_USER_ID=

# Optional defaults for Discord ingest metadata
DISCORD_INGEST_DEFAULT_TAGS=discord,imported
DISCORD_INGEST_DEFAULT_CATEGORY=General
DISCORD_INGEST_CONFIRMATIONS=1

# Optional: attempt to parse linked post pages (fxtwitter/x/twitter) for additional image URLs
DISCORD_INGEST_FETCH_EXTERNAL=1

# Max images imported per reaction/command (default 1)
DISCORD_INGEST_MAX_IMAGES_PER_POST=1

# Defaults used by Discord moderation buttons (/images review)
DISCORD_GENERATE_DEFAULT_COUNT=2
DISCORD_GENERATE_DEFAULT_MODE=shot-variation

# Auto-post variation mode buttons when an Approved status webhook message appears
DISCORD_APPROVED_VARIATION_BUTTONS=1
