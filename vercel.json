{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "bun install",
  "devCommand": "bun run dev:frontend",
  "rewrites": [
    {
      "source": "/docs/_mintlify/:path*",
      "destination": "https://v1su4.mintlify.app/_mintlify/:path*"
    },
    {
      "source": "/docs/api/request",
      "destination": "https://v1su4.mintlify.app/_mintlify/api/request"
    },
    {
      "source": "/docs",
      "destination": "https://v1su4.mintlify.app/docs"
    },
    {
      "source": "/docs/llms.txt",
      "destination": "https://v1su4.mintlify.app/llms.txt"
    },
    {
      "source": "/docs/llms-full.txt",
      "destination": "https://v1su4.mintlify.app/llms-full.txt"
    },
    {
      "source": "/docs/sitemap.xml",
      "destination": "https://v1su4.mintlify.app/sitemap.xml"
    },
    {
      "source": "/docs/robots.txt",
      "destination": "https://v1su4.mintlify.app/robots.txt"
    },
    {
      "source": "/docs/mcp",
      "destination": "https://v1su4.mintlify.app/mcp"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://v1su4.mintlify.app/docs/:path*"
    },
    {
      "source": "/mintlify-assets/:path+",
      "destination": "https://v1su4.mintlify.app/mintlify-assets/:path+"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
