{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "exit 0",
  "installCommand": "exit 0",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/Pindeck.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    }
  ]
}
