    "global": {
      "anchors": [
        {
          "anchor": "Pindeck",
          "href": "https://pindeck.v1siu4.dev",
          "icon": "grid-art"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/gordo-v1su4/pindeck",
          "icon": "github"
        }
