  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Core features",
            "pages": [
              "guides/uploading",
              "guides/boards",
              "guides/decks",
              "guides/ai-generation"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "guides/discord-bot",
              "guides/nextcloud"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/smart-analyze",
              "api-reference/endpoint/ingest-external",
              "api-reference/endpoint/discord-queue",
              "api-reference/endpoint/discord-moderate"
